{
  "name": "pengwin",
  "version": "1.0.0",
  "description": "A full stack web app that allows for a user to record and share wins",
  "scripts": {
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-client\"",
    "build-backend": "cd backend && npm run build",
    "test-backend": "cd backend && npm run test",
    "dev-backend": "cd backend && npm run dev",
    "prod-backend": "cd backend && npm run prod",
    "build-client": "cd client && npm run build",
    "test-client": "cd client && npm run test",
    "dev-client": "cd client && npm run dev",
    "prod-client": "cd client && npm run start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelklein24/pengwin.git"
  },
  "author": "michaelklein24",
  "license": "SEE LICENSE IN LICENSE.txt",
  "bugs": {
    "url": "https://github.com/michaelklein24/pengwin/issues"
  },
  "homepage": "https://github.com/michaelklein24/pengwin#readme",
  "dependencies": {
    "concurrently": "^9.2.4"
  }
}
