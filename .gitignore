# ==========================================
# Dependencies & Package Managers
# ==========================================
**/node_modules/
.pnp
.pnp.js

# ==========================================
# Next.js (Frontend)
# ==========================================
frontend/.next/
frontend/out/

# ==========================================
# TypeScript & Build Outputs (Backend/Frontend)
# ==========================================
# Ignores Express compiled TS output (typically 'dist' or 'build')
backend/dist/
backend/build/
frontend/build/
*.tsbuildinfo

# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
# Matches any .env files inside root, backend, or frontend
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.json

# ==========================================
# Logs and Debugging
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# Editors, IDEs & AI Tools (VS Code, Cursor, etc.)
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# System & OS Clutter
# ==========================================
